<!doctype html> 
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Retirement State Comparison Tool</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0f2540;          /* deep navy */
  --ink-2:#1c3a5e;
  --paper:#f6f4ee;        /* warm cream */
  --card:#ffffff;
  --line:#dcd7cb;
  --line-2:#e8e4da;
  --muted:#6b7280;
  --muted-2:#8a8f98;
  --accent:#a67c1f;       /* restrained gold */
  --accent-soft:#f3ead2;
  --good:#1f6b4f;
  --good-soft:#e3f0e8;
  --warn:#9a6a12;
  --warn-soft:#f7eed6;
  --bad:#9b2c2c;
  --bad-soft:#f6e2e1;
  --neutral:#3a4a5e;
  --shadow:0 1px 2px rgba(15,37,64,.06),0 6px 22px rgba(15,37,64,.06);
}
*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
  font-family:"IBM Plex Sans",-apple-system,sans-serif;
  background:var(--paper);
  color:var(--ink);
  line-height:1.5;
  font-size:15px;
  -webkit-font-smoothing:antialiased;
}
.num{font-family:"IBM Plex Mono",monospace;font-variant-numeric:tabular-nums;}
h1,h2,h3{font-family:"IBM Plex Serif",Georgia,serif;font-weight:600;letter-spacing:-.01em;margin:0;}
a{color:var(--accent)}

/* ---------- layout ---------- */
.wrap{max-width:1180px;margin:0 auto;padding:0 22px 70px}
header.site{
  background:linear-gradient(180deg,#0f2540 0%,#163357 100%);
  color:#f6f4ee;border-bottom:3px solid var(--accent);
}
.site-inner{max-width:1180px;margin:0 auto;padding:30px 22px 26px}
.brandrow{display:flex;align-items:baseline;gap:14px;flex-wrap:wrap}
.brandrow .badge{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--accent-soft);border:1px solid rgba(243,234,210,.35);padding:3px 9px;border-radius:999px}
header.site h1{font-size:30px;color:#fff;line-height:1.1}
header.site p{margin:10px 0 0;max-width:760px;color:#c9d4e2;font-size:14.5px}
header.site p.vintage{font-family:"IBM Plex Mono",monospace;font-size:11.5px;color:#8fa1b8;margin-top:8px;letter-spacing:.02em}

.section{margin-top:26px}
.section > h2{font-size:20px;display:flex;align-items:center;gap:10px;margin-bottom:4px}
.section > h2 .n{font-family:"IBM Plex Mono",monospace;font-size:12px;color:var(--accent);border:1px solid var(--accent);border-radius:6px;padding:1px 7px;font-weight:500}
.section .hint{color:var(--muted);font-size:13px;margin:2px 0 14px}

.panel{background:var(--card);border:1px solid var(--line);border-radius:14px;box-shadow:var(--shadow);padding:22px}

/* ---------- form ---------- */
.formgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px 18px}
.fieldgroup-title{grid-column:1/-1;font-family:"IBM Plex Serif",serif;font-size:14px;color:var(--ink-2);font-weight:600;border-bottom:1px solid var(--line-2);padding-bottom:6px;margin-top:6px}
.field-note{grid-column:1/-1;font-size:12.5px;color:var(--muted);background:#efece4;border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:8px;padding:9px 12px;line-height:1.5;margin:-2px 0 4px}
.fieldgroup-title:first-child{margin-top:0}
label.f{display:flex;flex-direction:column;gap:5px;font-size:12.5px;color:var(--neutral);font-weight:500}
label.f .lbl{display:flex;align-items:center;gap:6px}
label.f input,label.f select{
  font-family:inherit;font-size:14px;color:var(--ink);background:#fcfbf8;
  border:1px solid var(--line);border-radius:8px;padding:9px 10px;width:100%;
}
label.f input.num-in{font-family:"IBM Plex Mono",monospace}
label.f input:focus,label.f select:focus{outline:none;border-color:var(--ink-2);box-shadow:0 0 0 3px rgba(28,58,94,.12)}
.err-msg{color:var(--bad);font-size:12px;margin-top:2px}
.hidden{display:none !important}

/* ---------- state selector ---------- */
.presets{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.preset-btn{font-size:12.5px;font-family:"IBM Plex Mono",monospace;background:#fff;border:1px solid var(--line);color:var(--ink-2);padding:7px 11px;border-radius:999px;cursor:pointer;transition:.15s}
.preset-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-soft)}
.state-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:7px}
.state-chip{display:flex;align-items:center;gap:7px;font-size:13px;border:1px solid var(--line);border-radius:8px;padding:7px 9px;cursor:pointer;background:#fcfbf8;user-select:none;transition:.12s}
.state-chip:hover{border-color:var(--ink-2)}
.state-chip.sel{background:var(--ink);color:#fff;border-color:var(--ink)}
.state-chip input{accent-color:var(--accent);margin:0}
.sel-count{font-size:13px;color:var(--muted);margin-top:12px}
.sel-count.bad{color:var(--bad);font-weight:600}

/* ---------- buttons ---------- */
.actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}
.btn{font-family:inherit;font-size:14px;font-weight:600;border-radius:9px;padding:11px 18px;cursor:pointer;border:1px solid transparent;transition:.15s}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:#8c681a}
.btn-ghost{background:#fff;border-color:var(--line);color:var(--ink-2)}
.btn-ghost:hover{border-color:var(--ink-2)}
.toast{position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--ink);color:#fff;padding:11px 20px;border-radius:10px;font-size:14px;opacity:0;pointer-events:none;transition:.25s;z-index:50;box-shadow:var(--shadow)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ---------- summary cards ---------- */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px}
.card{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:16px 16px 15px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.card .k{font-size:11.5px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:600}
.card .v{font-family:"IBM Plex Mono",monospace;font-size:23px;font-weight:600;margin-top:7px;line-height:1.15}
.card .sub{font-size:12px;color:var(--muted);margin-top:4px}
.card.accent-good{border-top:3px solid var(--good)}
.card.accent-bad{border-top:3px solid var(--bad)}
.card.accent-gold{border-top:3px solid var(--accent)}
.card.accent-ink{border-top:3px solid var(--ink-2)}

/* ---------- tables ---------- */
.tablewrap{overflow-x:auto;border:1px solid var(--line);border-radius:12px;background:#fff;box-shadow:var(--shadow)}
table{border-collapse:collapse;width:100%;font-size:13px}
thead th{background:var(--ink);color:#eaf0f7;font-weight:600;text-align:right;padding:11px 12px;white-space:nowrap;font-size:12px;letter-spacing:.01em;position:sticky;top:0}
thead th:first-child,thead th.left{text-align:left}
tbody td{padding:10px 12px;border-bottom:1px solid var(--line-2);text-align:right;white-space:nowrap}
tbody td:first-child,tbody td.left{text-align:left}
tbody tr:nth-child(even){background:#faf8f3}
tbody tr:hover{background:var(--accent-soft)}
.cell-num{font-family:"IBM Plex Mono",monospace;font-variant-numeric:tabular-nums}
.rankbadge{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;font-family:"IBM Plex Mono",monospace;font-weight:600;font-size:12px}
.rank-1{background:var(--good);color:#fff}
.rank-last{background:var(--bad-soft);color:var(--bad)}
.rank-mid{background:var(--line-2);color:var(--ink-2)}
.statecell{font-weight:600}
.statecell .abbr{font-family:"IBM Plex Mono",monospace;color:var(--muted);font-weight:500;font-size:11.5px;margin-left:5px}
.est-tag{font-family:"IBM Plex Mono",monospace;font-size:9.5px;letter-spacing:.05em;color:var(--warn);background:var(--warn-soft);border-radius:4px;padding:1px 5px;margin-left:6px;vertical-align:middle}
.verdict{display:inline-block;font-size:11.5px;font-weight:600;padding:3px 8px;border-radius:6px;white-space:normal}
.v-good{background:var(--good-soft);color:var(--good)}
.v-warn{background:var(--warn-soft);color:var(--warn)}
.v-bad{background:var(--bad-soft);color:var(--bad)}
.v-neutral{background:var(--line-2);color:var(--ink-2)}
.yes{color:var(--bad);font-weight:600}
.no{color:var(--good);font-weight:600}
.partial{color:var(--warn);font-weight:600}
.neg{color:var(--good)}
.conf{font-family:"IBM Plex Mono",monospace;font-size:9.5px;letter-spacing:.04em;border-radius:4px;padding:1px 5px;margin-left:6px;vertical-align:middle;font-weight:600}
.conf-High{color:var(--good);background:var(--good-soft)}
.conf-Medium{color:var(--warn);background:var(--warn-soft)}
.conf-Low{color:var(--bad);background:var(--bad-soft)}
.assump{font-size:12px;color:var(--muted);background:#efece4;border:1px solid var(--line);border-radius:8px;padding:10px 13px;margin:10px 0 0;line-height:1.55}
.warn-banner{background:var(--bad-soft);border:1px solid var(--bad);border-left:4px solid var(--bad);border-radius:10px;padding:13px 16px;margin:0 0 18px;color:var(--ink);font-size:13.5px;line-height:1.55}
.warn-banner strong{color:var(--bad)}
.warn-banner .wb-title{display:block;font-weight:700;color:var(--bad);margin-bottom:3px;font-size:13px;letter-spacing:.01em}

/* ---------- red flags ---------- */
.flagcols{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}
.flagcard{background:#fff;border:1px solid var(--line);border-radius:12px;padding:16px;box-shadow:var(--shadow)}
.flagcard h3{font-size:16px;display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:10px}
.flagcard h3 .score{font-family:"IBM Plex Mono",monospace;font-size:12px;font-weight:500;color:var(--muted)}
.flag{display:flex;gap:9px;align-items:flex-start;padding:8px 0;border-top:1px solid var(--line-2);font-size:12.5px;color:var(--neutral)}
.flag:first-of-type{border-top:none}
.flag .dot{flex:0 0 auto;width:9px;height:9px;border-radius:50%;margin-top:5px}
.flag.sev-high .dot{background:var(--bad)}
.flag.sev-med .dot{background:var(--warn)}
.flag.sev-low .dot{background:var(--accent)}
.flag .ft{font-weight:600;color:var(--ink);display:block;margin-bottom:1px}
.noflags{font-size:13px;color:var(--good);display:flex;gap:8px;align-items:center;padding:8px 0}

/* ---------- recommendation ---------- */
.reco{background:#fff;border:1px solid var(--line);border-left:4px solid var(--accent);border-radius:12px;padding:22px 24px;box-shadow:var(--shadow)}
.reco h3{font-size:17px;margin:18px 0 6px}
.reco h3:first-child{margin-top:0}
.reco p{margin:0 0 11px;font-size:14.5px;color:#243449;line-height:1.62}
.reco p strong{color:var(--ink)}
.reco .band{display:inline-block;font-family:"IBM Plex Mono",monospace;font-size:11.5px;background:var(--accent-soft);color:#7a5c14;padding:3px 9px;border-radius:6px;margin-bottom:12px}
.reco ul{margin:0 0 12px;padding-left:20px}
.reco li{font-size:14px;margin-bottom:6px;color:#243449}
.reco li b{color:var(--ink)}

/* ---------- footer ---------- */
.disclaimer{margin-top:30px;font-size:12.5px;color:var(--muted);background:#efece4;border:1px solid var(--line);border-radius:10px;padding:16px 18px;line-height:1.6}
.disclaimer strong{color:var(--ink-2)}
.profile-readout{font-size:13px;color:var(--neutral);display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:6px 22px;margin-bottom:4px}
.profile-readout .pr{display:flex;justify-content:space-between;gap:10px;border-bottom:1px dotted var(--line);padding:4px 0}
.profile-readout .pr span:last-child{font-family:"IBM Plex Mono",monospace;color:var(--ink)}

#report.empty-state{text-align:center;color:var(--muted);padding:40px 20px;border:1px dashed var(--line);border-radius:14px;background:#fbfaf6}
#report.empty-state h2{color:var(--ink-2);margin-bottom:8px}

/* ---------- print ---------- */
@media print{
  body{background:#fff;font-size:11.5px}
  header.site{background:#fff !important;color:#000;border-bottom:2px solid #000;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  header.site h1{color:#000}
  header.site p,.brandrow .badge{color:#333;border-color:#999}
  .no-print{display:none !important}
  .panel,.card,.flagcard,.reco,.tablewrap{box-shadow:none}
  thead th{background:#22364f !important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  .verdict,.rankbadge,.card,.v-good,.v-bad,.v-warn{-webkit-print-color-adjust:exact;print-color-adjust:exact}
  .wrap{padding-bottom:10px}
  .section{break-inside:avoid}
  .tablewrap{overflow:visible}
}
</style>
</head>
<body>

<header class="site">
  <div class="site-inner">
    <div class="brandrow">
      <h1>Retirement State Comparison Tool</h1>
      <span class="badge">Education only</span>
    </div>
    <p>Compare 2 to 4 states on retirement taxes, Social Security treatment, property taxes, insurance, healthcare, and cost-of-living differences. This is a state-level planning model, not a full retirement projection.</p>
    <p class="vintage" id="vintage"></p>
  </div>
</header>

<div class="wrap">

  <!-- ===================== INPUTS ===================== -->
  <div class="section no-print">
    <h2><span class="n">1</span> Your Retirement Profile</h2>
    <p class="hint">A sample profile is preloaded. Change anything and recalculate. All math runs in your browser — nothing is uploaded.</p>
    <div class="panel">
      <div class="formgrid" id="formgrid"><!-- built by JS --></div>
    </div>
  </div>

  <!-- ===================== STATE SELECT ===================== -->
  <div class="section no-print">
    <h2><span class="n">2</span> States to Compare</h2>
    <p class="hint">Choose 2 to 4 states (50 states + Washington, D.C.). Use a preset or pick your own.</p>
    <div class="panel">
      <div class="presets" id="presets"></div>
      <div class="state-grid" id="stateGrid"></div>
      <div class="sel-count" id="selCount"></div>
    </div>
    <div class="actions">
      <button class="btn btn-primary" id="btnCalc">Calculate Comparison</button>
      <button class="btn btn-ghost" id="btnReset">Reset to Sample Profile</button>
      <button class="btn btn-ghost" id="btnCopy">Copy Report</button>
      <button class="btn btn-ghost" id="btnCsv">Export Summary as CSV</button>
      <button class="btn btn-ghost" id="btnPrint">Print Report</button>
    </div>
  </div>

  <!-- ===================== REPORT ===================== -->
  <div id="report" class="empty-state">
    <h2>Your comparison report will appear here</h2>
    <p>Enter your details above, pick your states, and press <strong>Calculate Comparison</strong>.</p>
  </div>

  <div class="disclaimer">
    <strong>Disclaimer.</strong> This tool is for education and planning only. It is not tax, legal, or financial advice.
    It compares <strong>state-level</strong> costs only and does <strong>not</strong> model federal income tax, investment growth,
    portfolio withdrawal sustainability, RMDs, Medicare/IRMAA surcharges, sequence-of-returns risk, home appreciation, or
    local/municipal income taxes. The tax treatment, cost-of-living, healthcare, and insurance figures are simplified estimates,
    states with more complex rules are marked <span class="est-tag">EST</span>, and each state carries a confidence rating.
    Data reflects 2025 tax-year rules (approximate). Confirm details with a qualified tax professional before making relocation
    or retirement decisions.
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
