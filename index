/* ---------- validation ---------- */
function validate(){
  let ok=true; const errs={};
  document.querySelectorAll("[data-err]").forEach(e=>{e.classList.add("hidden");e.textContent="";});
  const setErr=(k,msg)=>{ const e=document.querySelector(`[data-err="${k}"]`); if(e){e.textContent=msg;e.classList.remove("hidden");} ok=false; errs[k]=msg; };

  if(profile.netWorth<0) setErr("netWorth","Total net worth cannot be negative.");
  if(profile.horizon<1) setErr("horizon","Planning horizon must be at least 1 year.");
  if(profile.inflation<0 || profile.inflation>15) setErr("inflation","Use an inflation rate between 0 and 15%.");
  if(profile.ownership==="own" && profile.homeValue<0) setErr("homeValue","Home value cannot be negative.");
  if(profile.spending<0) setErr("spending","Annual spending cannot be negative.");
  ["ssIncome","pension","iraWithdrawals","rothWithdrawals","dividends","ltcg"].forEach(k=>{
    if(profile[k]<0) setErr(k,"This value cannot be negative.");
  });
  if(selectedStates.length<2){ toast("Select at least 2 states."); document.getElementById("selCount").classList.add("bad"); ok=false; }
  if(selectedStates.length>4){ toast("Select no more than 4 states."); ok=false; }
  return ok;
}

