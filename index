  rep.innerHTML=h;
}

function profileReadout(p){
  const F = (l,v)=>`<div class="pr"><span>${l}</span><span>${v}</span></div>`;
  const filingLabel={single:"Single",mfj:"Married filing jointly",mfs:"Married filing separately",hoh:"Head of household"}[p.filing];
