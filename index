  s+=F("Housing", p.ownership==="own"?`Own — ${fmtUSD(p.homeValue)}`:`Rent — ${fmtUSD(p.rent)}/yr`);
  const housingCash = calculateHousingCost(p);
  if(housingCash>0) s+=F("Annual housing cost", `${fmtUSD(housingCash)}/yr (same in all states)`);
  return s;
}

/* ===================== COPY / CSV / PRINT ===================== */
function buildReportText(){
  if(!lastRows) return "";
  const p=profile, rows=lastRows, horizon=Math.max(1,p.horizon);
  const best=rows[0], worst=rows[rows.length-1];
  const annualDiff=worst.impact-best.impact, horizonDiff=worst.cumulativeImpact-best.cumulativeImpact;
  const housingCash=calculateHousingCost(p);
  const money=v=>(v<0?"-":"")+fmtUSD(Math.abs(v));
  const L=[];
  L.push("RETIREMENT STATE COMPARISON — REPORT");
  L.push(`(Education only — not tax, legal, or financial advice. Data reviewed ${DATA_VINTAGE}.)`);
  L.push("");
  L.push("PROFILE");
  const fl={single:"Single",mfj:"Married filing jointly",mfs:"Married filing separately",hoh:"Head of household"}[p.filing];
  L.push(`  Filing status: ${fl}`);
  L.push(`  Age / Retirement age: ${p.age} / ${p.retireAge}   Horizon: ${p.horizon} yrs   Inflation: ${p.inflation||0}%/yr`);
  L.push(`  Total net worth: ${fmtUSD(p.netWorth)}`);
  L.push(`  Traditional IRA/401(k): ${fmtUSD(p.iraBalance)}   Roth: ${fmtUSD(p.rothBalance)}   Brokerage: ${fmtUSD(p.brokerage)}   Cash: ${fmtUSD(p.cash)}`);
  L.push(`  Income — SS ${fmtUSD(p.ssIncome)}, Pension ${fmtUSD(p.pension)}, Trad withdrawals ${fmtUSD(p.iraWithdrawals)}, Roth ${fmtUSD(p.rothWithdrawals)}, Div/Int ${fmtUSD(p.dividends)}, LTCG ${fmtUSD(p.ltcg)}`);
  L.push(`  Annual spending: ${fmtUSD(p.spending)}   Housing: ${p.ownership==="own"?"Own "+fmtUSD(p.homeValue):"Rent "+fmtUSD(p.rent)+"/yr"}${housingCash>0?`   Annual housing cost: ${fmtUSD(housingCash)}/yr (same in all states, excluded from ranking)`:""}`);
  L.push("");
  L.push("RANKING (best to worst by state-adjusted net worth estimate)");
  rows.forEach(r=>{
    L.push(`  #${r.rank} ${r.s.stateName} (${r.s.abbreviation}) [modeling confidence: ${r.confidence}]${r.s.estimated?" [EST]":""}`);
    L.push(`      Income tax ${fmtUSD(r.incomeTax)} | Property ${fmtUSD(r.propertyTax)} | Sales ${fmtUSD(r.salesTax)} | Insurance ${fmtUSD(r.ins)} | CoL adj ${money(r.col)} | Healthcare adj ${money(r.hc)}`);
    L.push(`      Annual state impact ${money(r.impact)} | cumulative impact (inflated) ${money(r.cumulativeImpact)} | state-adjusted net worth estimate ${fmtUSD(r.projected)}`);
    L.push(`      Verdict: ${verdictFor(p,r,rows).map(v=>v.t).join(", ")}`);
  });
  L.push("");
  L.push(`BEST: ${best.s.stateName}    WORST: ${worst.s.stateName}`);
  L.push(`Annual difference: ${fmtUSD(annualDiff)}    ${horizon}-year difference (inflation-adjusted): ${fmtUSD(horizonDiff)}`);
  L.push("");
  L.push("TAX TREATMENT");
  rows.forEach(r=>{
    const s=r.s;
    L.push(`  ${s.abbreviation}: SS ${s.socialSecurityTaxTreatment} | Pension ${s.pensionTaxTreatment} | IRA/401k ${s.ira401kTaxTreatment} | Roth not taxed | Int/Div ${s.hasStateIncomeTax?"taxed":"not taxed"} | LTCG ${s.capitalGainsTaxTreatment} | Estate ${s.hasEstateTax?"Yes":"No"} | Inheritance ${s.hasInheritanceTax?"Yes":"No"}`);
  });
  L.push("");
  L.push("RED FLAGS");
  rows.forEach(r=>{
    const flags=generateRedFlags(p,r.s,r);
    L.push(`  ${r.s.stateName}:`);
    if(!flags.length) L.push("      - No major red flags for this profile.");
    flags.forEach(f=> L.push(`      - ${f.title}: ${f.text}`));
  });
  L.push("");
  L.push("RECOMMENDATION");
  const tmp=document.createElement("div"); tmp.innerHTML=generateRecommendation(p,rows);
  tmp.querySelectorAll("li").forEach(li=> li.textContent="- "+li.textContent);
  L.push("  "+tmp.textContent.replace(/\s+/g," ").trim());
  L.push("");
  L.push("DISCLAIMER");
  L.push("  This tool is for education and planning only. It is not tax, legal, or financial advice.");
  L.push("  It compares STATE-LEVEL costs only and does NOT model federal income tax, investment");
  L.push("  growth, withdrawal sustainability, RMDs, Medicare/IRMAA, sequence risk, home appreciation,");
  L.push("  or local/municipal income taxes. State tax rules change often. Confirm details with a");
  L.push("  qualified tax professional before making relocation or retirement decisions.");
  return L.join("\n");
}

function copyReport(){
  if(!lastRows){ toast("Calculate a comparison first."); return; }
  const text=buildReportText();
  const done=()=>toast("Report copied to clipboard.");
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(done).catch(()=>fallbackCopy(text,done));
  } else fallbackCopy(text,done);
}
function fallbackCopy(text,cb){
  const ta=document.createElement("textarea"); ta.value=text; ta.style.position="fixed"; ta.style.opacity="0";
  document.body.appendChild(ta); ta.select();
  try{ document.execCommand("copy"); cb(); }catch(e){ toast("Copy failed — select and copy manually."); }
  document.body.removeChild(ta);
}

function exportCSV(){
  if(!lastRows){ toast("Calculate a comparison first."); return; }
  const horizon=Math.max(1,profile.horizon);
  const housingCash=calculateHousingCost(profile);
  const head=["Rank","State","Modeling Confidence","State Income Tax","Property Tax","Sales Tax","Insurance","Cost-of-Living Adjustment","Healthcare Adjustment","Annual State Impact","Cumulative Impact ("+horizon+"yr, "+(profile.inflation||0)+"% infl)","State-Adjusted Net Worth Estimate","Annual Housing Cost (state-independent)","Verdict"];
  const esc2=v=>{ v=String(v); return /[",\n]/.test(v)?'"'+v.replace(/"/g,'""')+'"':v; };
  const lines=[head.map(esc2).join(",")];
  lastRows.forEach(r=>{
    lines.push([r.rank, r.s.stateName, r.confidence, Math.round(r.incomeTax), Math.round(r.propertyTax), Math.round(r.salesTax),
      Math.round(r.ins), Math.round(r.col), Math.round(r.hc), Math.round(r.impact), Math.round(r.cumulativeImpact), Math.round(r.projected), Math.round(housingCash),
      verdictFor(profile,r,lastRows).map(v=>v.t).join("; ")].map(esc2).join(","));
  });
  const blob=new Blob([lines.join("\n")],{type:"text/csv;charset=utf-8;"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a"); a.href=url; a.download="retirement-state-comparison.csv";
  document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
  toast("CSV exported.");
}

function printReport(){
  if(!lastRows){ toast("Calculate a comparison first."); return; }
  window.print();
}

/* ===================== MISC ===================== */
let toastTimer;
function toast(msg){
  const t=document.getElementById("toast"); t.textContent=msg; t.classList.add("show");
  clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove("show"),2400);
}
function reset(){
  profile={...SAMPLE}; selectedStates=["PA","NJ","FL","TX"];
  buildForm(); buildStateGrid();
  lastRows=null;
  const rep=document.getElementById("report");
  rep.className="empty-state";
  rep.innerHTML=`<h2>Your comparison report will appear here</h2><p>Enter your details above, pick your states, and press <strong>Calculate Comparison</strong>.</p>`;
  toast("Reset to sample profile.");
}

