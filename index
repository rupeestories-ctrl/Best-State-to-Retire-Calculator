function parseNum(s){ if(typeof s==="number")return s; return Number(String(s).replace(/[^0-9.\-]/g,""))||0; }

function onFieldChange(e){
  const k=e.target.dataset.k, type=e.target.dataset.type;
  if(type==="select"){ profile[k]=e.target.value; }
  else { let v=parseNum(e.target.value); profile[k]= type==="int"? Math.round(v): v;
    e.target.value = type==="money"? fmtUSD(profile[k]) : profile[k]; }
  // toggle conditional fields
  document.querySelectorAll("label.f[data-k]").forEach(w=>{
    const f = FIELDS.find(x=>x.k===w.dataset.k);
    if(f && f.showIf){ w.classList.toggle("hidden", !f.showIf(profile)); }
  });
}

