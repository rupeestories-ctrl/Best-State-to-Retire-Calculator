  s+=F("Inflation assumption",`${p.inflation||0}%/yr`);
  s+=F("Total net worth",fmtUSD(p.netWorth));
  s+=F("Traditional IRA/401(k)",fmtUSD(p.iraBalance));
  s+=F("Roth balance",fmtUSD(p.rothBalance));
  s+=F("Social Security",fmtUSD(p.ssIncome)+"/yr");
  s+=F("Pension",fmtUSD(p.pension)+"/yr");
  s+=F("Traditional withdrawals",fmtUSD(p.iraWithdrawals)+"/yr");
  s+=F("Roth withdrawals",fmtUSD(p.rothWithdrawals)+"/yr");
  s+=F("Dividends/interest",fmtUSD(p.dividends)+"/yr");
  s+=F("Long-term cap gains",fmtUSD(p.ltcg)+"/yr");
