buildStateGrid();
document.getElementById("vintage").textContent = "State tax rules approximate 2025 tax year · data last reviewed "+DATA_VINTAGE+" · all calculations run locally in your browser";
document.getElementById("btnCalc").addEventListener("click",calculate);
document.getElementById("btnReset").addEventListener("click",reset);
document.getElementById("btnCopy").addEventListener("click",copyReport);
document.getElementById("btnCsv").addEventListener("click",exportCSV);
document.getElementById("btnPrint").addEventListener("click",printReport);
// Run once on load with the sample profile
calculate();
</script>
