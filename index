      h.className="fieldgroup-title"; h.textContent=f.group; grid.appendChild(h);
      continue;
    }
    if(f.note){
      const d = document.createElement("div");
      d.className="field-note"; d.textContent=f.note; grid.appendChild(d);
      continue;
    }
    const wrap = document.createElement("label");
    wrap.className="f"; wrap.dataset.k=f.k;
    if(f.showIf && !f.showIf(profile)) wrap.classList.add("hidden");
    const lbl = document.createElement("span"); lbl.className="lbl"; lbl.textContent=f.label;
    wrap.appendChild(lbl);
    let input;
    if(f.type==="select"){
      input = document.createElement("select");
      for(const [v,t] of f.opts){
        const o=document.createElement("option"); o.value=v; o.textContent=t; input.appendChild(o);
      }
      input.value = profile[f.k];
    } else {
      input = document.createElement("input");
      input.type="text"; input.inputMode= f.type==="money"?"numeric":"numeric";
      input.className="num-in";
      input.value = f.type==="money" ? fmtUSD(profile[f.k]) : profile[f.k];
    }
    input.dataset.k=f.k; input.dataset.type=f.type;
    input.addEventListener("change", onFieldChange);
    if(f.type!=="select") input.addEventListener("focus",()=>{
      const raw = parseNum(input.value); input.value = raw;
    });
    wrap.appendChild(input);
    const err=document.createElement("span"); err.className="err-msg hidden"; err.dataset.err=f.k;
    wrap.appendChild(err);
    grid.appendChild(wrap);
  }
