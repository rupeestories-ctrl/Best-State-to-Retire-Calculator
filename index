/* Data vintage — surfaced in the header, report, and exports. */
const DATA_VINTAGE = "May 2026";

/* Local/municipal income-tax notes (modeled as a flag + warning only). */
STATE_DATA.PA.localTaxNote = "Pennsylvania municipalities levy a local Earned Income Tax, but it generally applies to wages, not Social Security, pensions, or retirement-account withdrawals. Confirm for your specific municipality.";
STATE_DATA.NY.localTaxNote = "New York City and Yonkers levy their own resident income taxes on top of the state tax. This model does not include them — they can materially change the result if you live there.";
STATE_DATA.MD.localTaxNote = "Maryland counties levy 'piggyback' local income taxes (roughly 2.25%–3.2%) that DO apply to retirement income. This model does not include them, so Maryland's true income-tax cost is higher than shown.";
STATE_DATA.OH.localTaxNote = "Many Ohio municipalities and school districts levy local income taxes. These generally apply to earned income rather than retirement income, but confirm locally.";

/* Local taxes that can MATERIALLY change the income-tax result -> shown as a banner. */
STATE_DATA.MD.localTaxMaterial = "Maryland local income taxes (county 'piggyback' taxes of roughly 2.25%–3.2%) are not included and DO apply to retirement income. Actual income tax may be meaningfully higher than shown.";
STATE_DATA.NY.localTaxMaterial = "New York City and Yonkers resident income taxes are not included. If you would live in NYC or Yonkers, actual income tax may be meaningfully higher than shown.";

/* ===================== FORMATTING HELPERS ===================== */
const fmtUSD = (n)=>{
  if(n===null||n===undefined||isNaN(n)) return "$0";
  const neg = n<0; const v = Math.round(Math.abs(n));
  return (neg?"-$":"$")+v.toLocaleString("en-US");
};
const fmtPct = (r,dec=2)=> (r*100).toFixed(dec).replace(/\.?0+$/,m=> m.includes('.')?'':m)+"%";
const fmtPctFixed = (r,dec=2)=> (r*100).toFixed(dec)+"%";
const esc = (s)=> String(s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));

/* ===================== INCLUSION FRACTIONS ===================== */
function inclusionFraction(treatment){
  switch(treatment){
    case "not taxed": return 0;
    case "partially excluded":
    case "partially taxed": return 0.5;
    case "taxed":
    case "taxed as income": return 1;
    default: return 0;
  }
}
const FILING_FACTOR = { single:0.5, mfs:0.5, hoh:0.6, mfj:1.0 };

/* ===================== CALCULATION ENGINE ===================== */
function calculateAnnualIncome(p){
  return p.ssIncome + p.pension + p.iraWithdrawals + p.rothWithdrawals + p.dividends + p.ltcg;
}

function calculateStateTaxableIncome(p, s){
  if(!s.hasStateIncomeTax) return 0; // none of the ordinary-income items taxed
  let taxable = 0;
  taxable += inclusionFraction(s.socialSecurityTaxTreatment) * p.ssIncome;
  taxable += inclusionFraction(s.pensionTaxTreatment) * p.pension;
  taxable += inclusionFraction(s.ira401kTaxTreatment) * p.iraWithdrawals;
  // Roth never taxed
  taxable += p.dividends; // interest/dividends taxable where income tax exists
  // capital gains
  if(s.capitalGainsTaxTreatment === "taxed as income") taxable += p.ltcg;
  else if(s.capitalGainsTaxTreatment === "partially taxed") taxable += 0.5 * p.ltcg;
  // "not taxed"/"special" handled outside ordinary income
  return Math.max(0, taxable);
}

function calculateStateIncomeTax(taxableIncome, s, filingStatus){
  if(!s.hasStateIncomeTax) {
    // Special-case WA capital gains tax (separate from wage income)
    return 0;
  }
  if(s.incomeTaxType === "flat"){
    return taxableIncome * s.flatIncomeTaxRate;
  }
  if(s.incomeTaxType === "progressive" && s.progressiveBrackets.length){
    const f = FILING_FACTOR[filingStatus] || 1;
    let tax = 0, lower = 0;
    for(const b of s.progressiveBrackets){
      const upper = (b.upTo===Infinity)?Infinity:b.upTo*f;
      if(taxableIncome > lower){
        const slice = Math.min(taxableIncome, upper) - lower;
        if(slice>0) tax += slice * b.rate;
      }
      lower = upper;
      if(taxableIncome <= upper) break;
    }
    return tax;
  }
  return taxableIncome * (s.flatIncomeTaxRate||0);
}

// Separate special tax (e.g., WA long-term capital gains tax)
function calculateSpecialCapGainsTax(p, s){
  if(s.capitalGainsTaxTreatment === "special" && s.capGainsThreshold!=null){
    return Math.max(0, p.ltcg - s.capGainsThreshold) * (s.capGainsRate||0);
  }
  return 0;
}

function calculatePropertyTax(p, s){
  if(p.ownership !== "own") return 0;
  return Math.max(0,p.homeValue) * s.effectivePropertyTaxRate;
}

// Share of total spending assumed to be subject to sales tax. Most states
// exempt groceries/services/housing, so only a portion of a budget is taxed.
const SALES_TAXABLE_SHARE = 0.55;
function calculateSalesTax(p, s){
  const salesTaxableSpending = Math.max(0,p.spending) * SALES_TAXABLE_SHARE;
  return salesTaxableSpending * s.averageSalesTaxRate;
}

// Housing cost is state-INDEPENDENT here (the user enters one figure), so it
// does NOT affect the state ranking. It is reported separately for context.
function calculateHousingCost(p){
  if(p.ownership === "rent") return Math.max(0, p.rent||0);
  return Math.max(0, p.mortgage||0); // owner: cash mortgage outflow (0 if paid off)
}

const INSURANCE_DEFAULTS = { low:2000, medium:3500, high:6000, "very high":8000 };
function calculateInsuranceCost(p, s){
  if(p.ownership !== "own") return 0; // renters: no homeowners insurance modeled
  if(p.insurance && p.insurance>0) return p.insurance;
  return INSURANCE_DEFAULTS[s.insuranceRisk] || 3500;
}

function defaultHealthcare(p){
  const married = (p.filing==="mfj"||p.filing==="mfs");
  return married ? 16000 : 8000;
}
function healthcareBase(p){
  return (p.healthcare && p.healthcare>0) ? p.healthcare : defaultHealthcare(p);
}
// Relative healthcare adjustment vs the national baseline (can be ±).
function calculateHealthcareAdjustment(p, s){
  return healthcareBase(p) * ((s.healthcareCostIndex - 100) / 100);
}

// Cost-of-living adjustment applies ONLY to non-housing, non-healthcare,
// non-insurance living spending, so it does not double-count costs that are
// already modeled separately. It is a relative figure and can be negative.
function calculateCostOfLivingAdjustment(p, s){
  const housing = calculateHousingCost(p);
  const healthcare = healthcareBase(p);
  const insurance = calculateInsuranceCost(p, s);
  const baseLiving = Math.max(0, Math.max(0,p.spending) - housing - healthcare - insurance);
  return baseLiving * ((s.costOfLivingIndex - 100) / 100);
}

function calculateAnnualStateImpact(p, s){
  const taxable = calculateStateTaxableIncome(p,s);
  const incomeTax = calculateStateIncomeTax(taxable, s, p.filing) + calculateSpecialCapGainsTax(p,s);
  const propertyTax = calculatePropertyTax(p,s);
  const salesTax = calculateSalesTax(p,s);
  const ins = calculateInsuranceCost(p,s);
  const hc = calculateHealthcareAdjustment(p,s);
  const col = calculateCostOfLivingAdjustment(p,s);
  // Required costs are always >= 0; the cost-of-living / healthcare adjustments
  // are relative and can be positive or negative.
  const requiredCosts = incomeTax + propertyTax + salesTax + ins;
  const relativeAdj = col + hc;
  const impact = requiredCosts + relativeAdj; // "Annual state impact" (can be < 0)
  const housing = calculateHousingCost(p); // reported separately, not in ranking
  return { incomeTax, propertyTax, salesTax, ins, hc, col, taxable, requiredCosts, relativeAdj, impact, housing };
}

// Cumulative state impact over the horizon, with annual costs inflated by a
// flat compounding rate. Sum of a growing annuity:
//   impact * ((1+i)^n - 1) / i      (i > 0)
//   impact * n                      (i == 0)
function calculateCumulativeImpact(p, s, horizon, obj){
  const annual = (obj||calculateAnnualStateImpact(p,s)).impact;
  const n = Math.max(1, horizon);
  const i = Math.max(0, (p.inflation||0)) / 100;
  const cumulativeImpact = i > 0 ? annual * (Math.pow(1+i, n) - 1) / i : annual * n;
  return { cumulativeImpact, projected: p.netWorth - cumulativeImpact };
}

// Modeling confidence: how closely this model captures the state's tax rules
// (i.e. how simplified the calculation is), NOT whether figures are verified.
// No-income-tax states are simple to model; progressive states with
// age/income-based exclusions are the most simplified.
function stateConfidence(s){
  if(!s.hasStateIncomeTax) return "High";
  const hasPartial = [s.socialSecurityTaxTreatment,s.pensionTaxTreatment,s.ira401kTaxTreatment,s.capitalGainsTaxTreatment]
    .some(t=> t==="partially excluded" || t==="partially taxed");
  if(s.incomeTaxType==="progressive" && hasPartial) return "Low";
  return "Medium";
}

function rankStates(p, selected){
  const horizon = Math.max(1, p.horizon);
  const rows = selected.map(abbr=>{
    const s = STATE_DATA[abbr];
    const d = calculateAnnualStateImpact(p,s);
    const nw = calculateCumulativeImpact(p,s,horizon,d);
    return {
      abbr, s, ...d,
      confidence: stateConfidence(s),
      cumulativeImpact: nw.cumulativeImpact,
      projected: nw.projected
    };
  });
  rows.sort((a,b)=>{
    if(b.projected !== a.projected) return b.projected - a.projected;       // higher remaining NW first
    if(a.impact !== b.impact) return a.impact - b.impact;                   // lower annual impact
    if(a.incomeTax !== b.incomeTax) return a.incomeTax - b.incomeTax;       // lower income tax
    if(a.propertyTax !== b.propertyTax) return a.propertyTax - b.propertyTax; // lower property tax
    const estA = (a.s.hasEstateTax||a.s.hasInheritanceTax)?1:0;
    const estB = (b.s.hasEstateTax||b.s.hasInheritanceTax)?1:0;
    if(estA !== estB) return estA - estB;                                   // no estate/inheritance preferred
    return a.s.costOfLivingIndex - b.s.costOfLivingIndex;                   // lower COL
  });
  rows.forEach((r,i)=> r.rank = i+1);
  return rows;
}

/* ===================== VERDICT LOGIC ===================== */
function verdictFor(p, r, rows){
  const labels = [];
  const s = r.s;
  const isBest = r.rank===1;
  const isWorst = r.rank===rows.length;
  const homeOwner = p.ownership==="own";
  const bigIra = p.iraBalance >= 1500000 || p.iraWithdrawals >= 100000;
  const rothHeavy = p.rothBalance > (p.iraBalance + p.brokerage) && p.rothBalance>0;

  if(isBest) labels.push({t:"Best overall fit",c:"v-good"});
  if(!s.hasStateIncomeTax) labels.push({t:"Strong tax state",c:"v-good"});
  if(s.hasStateIncomeTax && (s.ira401kTaxTreatment==="not taxed") && (s.pensionTaxTreatment==="not taxed"))
    labels.push({t:"Retirement income friendly",c:"v-good"});
  if(!s.hasStateIncomeTax && homeOwner && r.propertyTax > r.salesTax*1.5)
    labels.push({t:"Low income tax, watch property tax",c:"v-warn"});
  if(homeOwner && r.propertyTax >= 12000) labels.push({t:"High property tax",c:"v-warn"});
  if(r.col >= p.spending*0.08) labels.push({t:"High cost-of-living burden",c:"v-warn"});
  if(s.hasEstateTax) labels.push({t:"Estate tax risk",c:"v-warn"});
  if(s.hasInheritanceTax) labels.push({t:"Inheritance tax risk",c:"v-warn"});
  if(bigIra && (s.ira401kTaxTreatment==="taxed")) labels.push({t:"Risky for large IRA balances",c:"v-bad"});
  if(rothHeavy) labels.push({t:"Better for Roth-heavy retirees",c:"v-good"});
  if(!homeOwner && !s.hasStateIncomeTax) labels.push({t:"Good if renting",c:"v-good"});
  if(isWorst && rows.length>1) labels.push({t:"Expensive for this profile",c:"v-bad"});

  // de-dup by text
  const seen=new Set(); const out=[];
  for(const l of labels){ if(!seen.has(l.t)){seen.add(l.t);out.push(l);} }
  if(!out.length) out.push({t:"Balanced profile",c:"v-neutral"});
  return out.slice(0,3);
}

/* ===================== RED FLAGS ===================== */
function generateRedFlags(p, s, r){
  const flags=[];
  const homeOwner = p.ownership==="own";
  const push=(sev,title,text)=> flags.push({sev,title,text});

  if(inclusionFraction(s.socialSecurityTaxTreatment)>0 && p.ssIncome>0)
    push("high","Taxes Social Security",`${s.stateName} taxes at least part of Social Security benefits. With ${fmtUSD(p.ssIncome)}/yr in benefits, that adds to your state tax bill.`);
  if(inclusionFraction(s.ira401kTaxTreatment)>=1 && p.iraWithdrawals>0)
    push("high","Taxes IRA/401(k) withdrawals",`Your ${fmtUSD(p.iraWithdrawals)}/yr of traditional withdrawals are fully taxable here, which is a recurring annual drag.`);
  else if(inclusionFraction(s.ira401kTaxTreatment)>0 && p.iraWithdrawals>0)
    push("med","Partially taxes IRA/401(k) withdrawals",`Part of your ${fmtUSD(p.iraWithdrawals)}/yr of traditional withdrawals may be taxable after exclusions.`);
  if(inclusionFraction(s.pensionTaxTreatment)>=1 && p.pension>0)
    push("med","Taxes pension income",`Your ${fmtUSD(p.pension)}/yr pension is taxed as income in ${s.stateName}.`);
  if(homeOwner && r.propertyTax >= 12000)
    push("high","High property tax",`At an effective rate near ${fmtPct(s.effectivePropertyTaxRate)}, your home implies about ${fmtUSD(r.propertyTax)}/yr in property tax.`);
  else if(homeOwner && s.effectivePropertyTaxRate>=0.015)
    push("med","Elevated property tax",`${s.stateName}'s effective property-tax rate (~${fmtPct(s.effectivePropertyTaxRate)}) is above the national norm.`);
  if(s.averageSalesTaxRate >= 0.085)
    push("med","High sales tax",`Combined sales tax averages about ${fmtPct(s.averageSalesTaxRate)} here, which adds up across everyday spending.`);
  if(s.costOfLivingIndex >= 115)
    push("high","High cost of living",`Cost of living runs roughly ${s.costOfLivingIndex-100}% above the national baseline, so your ${fmtUSD(p.spending)}/yr budget stretches less.`);
  else if(s.costOfLivingIndex >= 108)
    push("med","Above-average cost of living",`Cost of living is about ${s.costOfLivingIndex-100}% above baseline.`);
  if(s.healthcareCostIndex >= 107)
    push("med","High healthcare cost","Healthcare costs here run meaningfully above the national average.");
  if(homeOwner && (s.insuranceRisk==="high"||s.insuranceRisk==="very high"))
    push(s.insuranceRisk==="very high"?"high":"med","High home insurance risk",`${s.stateName} carries ${s.insuranceRisk} property-insurance risk; default modeled premium is ${fmtUSD(INSURANCE_DEFAULTS[s.insuranceRisk])}/yr.`);
  if(s.hasEstateTax)
    push(p.netWorth>=2000000?"high":"med","Estate tax risk",`${s.stateName} levies a state estate tax. With a ${fmtUSD(p.netWorth)} net worth, review exemption thresholds.`);
  if(s.hasInheritanceTax)
    push(p.netWorth>=2000000?"high":"med","Inheritance tax risk",`${s.stateName} has an inheritance tax that can apply to what heirs receive depending on their relationship to you.`);
  if(s.localTaxNote)
    push("med","Local income tax may apply",s.localTaxNote);
  // Age-gated retirement exclusions: many states' partial exclusions only apply
  // at 59½/62/65. Below that, withdrawals may be taxed more than this model shows.
  const hasAgeGatedExclusion = [s.pensionTaxTreatment,s.ira401kTaxTreatment]
    .some(t=> t==="partially excluded") && s.hasStateIncomeTax;
  if(hasAgeGatedExclusion && p.age < 65 && (p.iraWithdrawals>0 || p.pension>0))
    push("med","Age-based retirement exclusion","This state's retirement-income exclusions are often age-gated (commonly 59½, 62, or 65). At age "+p.age+", your actual exclusion may be smaller than this simplified model assumes.");

  return flags;
}

/* ===================== RECOMMENDATION ===================== */
function netWorthBand(nw){
  if(nw < 1000000) return {key:"u1", label:"Under $1,000,000",
    focus:"cost of living, rent, property tax, and healthcare costs"};
  if(nw < 2000000) return {key:"1to2", label:"$1,000,000 – $2,000,000",
    focus:"state income tax, property tax, and your retirement withdrawal strategy"};
  if(nw < 5000000) return {key:"2to5", label:"$2,000,000 – $5,000,000",
    focus:"IRA/401(k) withdrawal taxation, RMD exposure, property tax, Medicare IRMAA awareness, and estate or inheritance tax risk"};
  return {key:"o5", label:"Above $5,000,000",
    focus:"estate tax, inheritance tax, capital gains, large IRA balances, property tax, and multi-state planning risk"};
}

function generateRecommendation(p, rows){
  const best = rows[0];
  const worst = rows[rows.length-1];
  const horizon = Math.max(1,p.horizon);
  const annualDiff = worst.impact - best.impact;
  const horizonDiff = worst.cumulativeImpact - best.cumulativeImpact;
  const band = netWorthBand(p.netWorth);

  // superlatives
  const pureTax = [...rows].sort((a,b)=> a.incomeTax - b.incomeTax)[0];
  const lowCost = [...rows].sort((a,b)=> (a.col+a.salesTax+a.hc) - (b.col+b.salesTax+b.hc))[0];
  const hiddenCost = [...rows].sort((a,b)=> (b.propertyTax+b.ins+b.salesTax) - (a.propertyTax+a.ins+a.salesTax))[0];
  // looks cheap but isn't: no income tax yet high impact
  const looksCheap = [...rows].filter(r=>!r.s.hasStateIncomeTax).sort((a,b)=> b.impact-a.impact)[0];
  // looks expensive but tax friendly: has income tax but low income tax due to retirement treatment
  const looksPricey = [...rows].filter(r=>r.s.hasStateIncomeTax).sort((a,b)=> a.incomeTax-b.incomeTax)[0];

  let html = `<span class="band">Net-worth band: ${band.label}</span>`;
  html += `<p>Across the states you compared over a ${horizon}-year horizon, <strong>${best.s.stateName}</strong> comes out ahead, leaving an estimated <strong>${fmtUSD(best.projected)}</strong> versus <strong>${fmtUSD(worst.projected)}</strong> in ${worst.s.stateName} — a gap of about <strong>${fmtUSD(horizonDiff)}</strong> (${fmtUSD(annualDiff)} per year).</p>`;

  // net-worth-band commentary
  html += `<p>At your net worth, the factors that matter most are ${band.focus}.</p>`;

  // headline structured read
  html += `<h3>How the states stack up</h3><ul>`;
  html += `<li><b>Best overall:</b> ${best.s.stateName} — lowest total annual state impact for your specific mix of income, housing, and spending.</li>`;
  html += `<li><b>Best on pure income tax:</b> ${pureTax.s.stateName} (${fmtUSD(pureTax.incomeTax)}/yr of modeled state income tax).</li>`;
  html += `<li><b>Lowest day-to-day cost:</b> ${lowCost.s.stateName} — best combination of cost of living, sales tax, and healthcare.</li>`;
  html += `<li><b>Highest hidden costs:</b> ${hiddenCost.s.stateName} — property tax, insurance, and sales tax add ${fmtUSD(hiddenCost.propertyTax+hiddenCost.ins+hiddenCost.salesTax)}/yr.</li>`;
  if(looksCheap && looksCheap.impact > best.impact*1.05)
    html += `<li><b>Looks cheap but may not be:</b> ${looksCheap.s.stateName} has no state income tax, yet its total annual impact is ${fmtUSD(looksCheap.impact)}/yr once property tax, insurance, and other costs are counted.</li>`;
  if(looksPricey && pureTax.s.hasStateIncomeTax===false && looksPricey.incomeTax < worst.incomeTax)
    html += `<li><b>Looks expensive but is retiree-friendly:</b> ${looksPricey.s.stateName} has an income tax on paper, but its retirement-income treatment keeps your modeled state income tax to about ${fmtUSD(looksPricey.incomeTax)}/yr.</li>`;
  html += `</ul>`;

  // personalized drivers
  html += `<h3>What's driving your result</h3>`;
  const drivers=[];
  if(p.iraWithdrawals >= 60000)
    drivers.push(`Because your plan uses ${fmtUSD(p.iraWithdrawals)}/yr from traditional retirement accounts, states that tax IRA and 401(k) withdrawals create a real annual drag — that single factor reshuffles the ranking.`);
  if(p.ownership==="own" && p.homeValue >= 750000)
    drivers.push(`Because your home value is ${fmtUSD(p.homeValue)}, property tax can matter as much as income tax. A no-income-tax state is not automatically the lowest-cost state once the property-tax bill is included.`);
  const rothShare = p.rothWithdrawals / Math.max(1, calculateAnnualIncome(p));
  if(rothShare >= 0.4 || (p.rothBalance > (p.iraBalance+p.brokerage) && p.rothBalance>0))
    drivers.push(`Because much of your retirement income comes from Roth accounts, state income tax matters less — Roth withdrawals are generally not state-taxed. Property tax, insurance, and cost of living become the bigger drivers.`);
  if(p.netWorth >= 5000000)
    drivers.push(`Because your net worth is above $5 million, estate and inheritance tax rules should be reviewed before choosing a state — at this level they can outweigh annual income-tax differences.`);
  if(p.ssIncome===0)
    drivers.push(`You reported no Social Security income, so SS taxation is not a meaningful factor in your comparison.`);
  if(p.ownership==="rent")
    drivers.push(`Because you rent, property tax and homeowners insurance are zero in every state — so cost of living, sales tax, and healthcare decide the ranking instead. Your rent is the same wherever you go, so it does not change which state ranks best.`);
  if(!drivers.length)
    drivers.push(`Your income is reasonably balanced across sources, so the ranking is driven by the combination of income tax, property tax, and cost of living rather than any single factor.`);
  for(const d of drivers) html += `<p>${d}</p>`;

  // example-tone narrative on the actual best/worst
  html += `<h3>Plain-English takeaway</h3>`;
  html += `<p>${narrativeTakeaway(p, rows)}</p>`;

  return html;
}

function narrativeTakeaway(p, rows){
  const parts = rows.map(r=>{
    const s=r.s;
    if(!s.hasStateIncomeTax){
      let t = `${s.stateName} wins on income tax because it does not tax wages or retirement income`;
      if(r.propertyTax >= 12000) t += `, but it is not automatically cheapest — property tax runs about ${fmtUSD(r.propertyTax)}/yr`;
      else if(s.insuranceRisk==="very high"||s.insuranceRisk==="high") t += `, though higher home-insurance risk offsets some of that benefit`;
      return t + ".";
    }
    if(s.ira401kTaxTreatment==="not taxed" && s.pensionTaxTreatment==="not taxed"){
      return `${s.stateName} may be surprisingly strong for retirees because many retirement distributions are not taxed at the state level` + (s.hasInheritanceTax?", though its inheritance tax is worth reviewing":"") + ".";
    }
    if(s.ira401kTaxTreatment==="taxed"){
      return `${s.stateName} can carry higher annual drag because IRA/401(k) withdrawals${inclusionFraction(s.socialSecurityTaxTreatment)>0?" and part of Social Security":""} are taxed` + (s.costOfLivingIndex>=115?", on top of a high cost of living":"") + ".";
    }
    return `${s.stateName} sits in the middle — an income tax applies, but retirement-income exclusions soften it.`;
  });
  return parts.join(" ");
}

/* ===================== TAX-TREATMENT DISPLAY ===================== */
function ssDisplay(t){ if(t==="not taxed")return['no','No']; if(t==="taxed")return['yes','Yes']; return['partial','Partial']; }
function incDisplay(t){ if(t==="not taxed")return['no','No']; if(t==="taxed"||t==="taxed as income")return['yes','Yes']; return['partial','Partial']; }
function cgDisplay(t){
  if(t==="not taxed")return['no','No'];
  if(t==="taxed as income")return['yes','As income'];
  if(t==="partially taxed")return['partial','Partial'];
  if(t==="special")return['partial','Large gains'];
  return['partial','—'];
}

